{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "//": "[Opus 4.8] added node types so *.test.ts typecheck (was a silent CI failure)",
  "include": ["src"]
}
